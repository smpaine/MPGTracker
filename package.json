  "license": "MIT",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "postinstall": "node -e \"if(process.platform==='freebsd'){var fs=require('fs');var src=require.resolve('@rollup/wasm-node/package.json').replace('/package.json','');var dst=require.resolve('rollup/package.json').replace('/package.json','');fs.rmSync(dst,{recursive:true,force:true});fs.cpSync(src,dst,{recursive:true});console.log('Patched rollup with WASM build for FreeBSD');}\"",
    "test": "ng test",
    "lint": "ng lint",
    "e2e": "ng e2e"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.3.17",
    "@angular/cdk": "^20.2.14",
    "@angular/common": "^20.3.17",
    "@angular/compiler": "^20.3.17",
    "@angular/core": "^20.3.17",
    "@angular/forms": "^20.3.17",
    "@angular/material": "^20.2.14",
    "@angular/platform-browser": "^20.3.17",
    "@angular/platform-browser-dynamic": "^20.3.17",
    "@angular/router": "^20.3.17",
    "core-js": "^2.4.1",
    "hammerjs": "^2.0.8",
    "npm": "^8.11.0",
    "rxjs": "^6.6.7",
    "rxjs-compat": "^6.4.0",
    "tslib": "^2.0.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.3.19",
